<UserControl x:Class="Sprout.Core.Views.MainView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:Sprout.Core.Views"
             xmlns:viewModels="clr-namespace:Sprout.Core.ViewModels"
             Name="MainViewControl"
             
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800"
             d:DataContext="{d:DesignInstance viewModels:MainViewVM}">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition/>
            <RowDefinition/>
            <RowDefinition/>
        </Grid.RowDefinitions>

        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="1*"/>
            <ColumnDefinition Width="4*"/>
        </Grid.ColumnDefinitions>

        <ItemsControl x:Name="ButtonsList"
                      Grid.Column="0"
                      Grid.Row="0"
                      Grid.RowSpan="3"
                      ItemsSource="{Binding PageConfigs}" >
            <ItemsControl.ItemTemplate>
                <DataTemplate>
                    <Button
                        Content="{Binding Title}"
                        Command="{Binding ElementName=MainViewControl, Path=DataContext.OpenPageCommand }"
                        CommandParameter="{Binding}"
                        />
                </DataTemplate>
            </ItemsControl.ItemTemplate>
        </ItemsControl>

        <TabControl Name="MyTabControl" 
                    Grid.Column="1"
                    Grid.Row="0"
                    Grid.RowSpan="3"
                    ItemsSource="{Binding Tabs}"
                    SelectedItem="{Binding SelectedTab}">

            <TabControl.Resources>
                <DataTemplate DataType="{x:Type viewModels:SproutPageVM}">
                    <local:SproutPage />
                </DataTemplate>
            </TabControl.Resources>

            <TabControl.ItemTemplate>
                <DataTemplate>
                    <TextBlock Text="{Binding PageConfig.Title}" />
                </DataTemplate>
            </TabControl.ItemTemplate>

        </TabControl>
    </Grid>
</UserControl>
