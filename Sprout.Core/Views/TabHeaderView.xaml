    Name="TabHeaderStackPanel" Orientation="Horizontal" >

    <TextBlock Text="{Binding PageConfig.Title}" />
    <!--MouseDown="Grid_MouseDown"-->
    <!--MouseDown="TabHeaderStackPanel_MouseDown">-->
