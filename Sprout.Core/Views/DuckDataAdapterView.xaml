<UserControl x:Class="Sprout.Core.Views.DuckDataAdapterView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:Sprout.Core.Views"
             xmlns:viewModels="clr-namespace:Sprout.Core.ViewModels"
             xmlns:avalonedit="http://icsharpcode.net/sharpdevelop/avalonedit"

             mc:Ignorable="d" 
             Background="#ffd04d"
             d:DataContext="{d:DesignInstance viewModels:DuckDataAdapterVM}"
             d:DesignHeight="450" d:DesignWidth="800">
    <ScrollViewer>
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <Expander Header="Duck Data Adapter Settings"
                  Grid.Row="0"
                  IsExpanded="True"
                  Margin="5">
                <StackPanel Margin="10">
                    <StackPanel Orientation="Vertical"
                                Margin="0,0,0,5">
                        <Label Content="Connection String:" Width="120"
                               HorizontalAlignment="Left"
                               VerticalAlignment="Center"/>
                        <TextBox MinWidth="200"
                                 HorizontalAlignment="Left"
                                 Text="{Binding DataAdapter.ConnectionString, UpdateSourceTrigger=PropertyChanged}"/>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,5">
                        <Label Content="Command Timeout (seconds):" Width="120" VerticalAlignment="Center"/>
                        <TextBox Width="100" Text="{Binding CommandTimeout, UpdateSourceTrigger=PropertyChanged}"/>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,5,0,0">
                        <CheckBox Content="Defer initial load"
                                  ToolTip="When checked the initial data load is skipped on page load."
                                  VerticalAlignment="Center"
                                  IsChecked="{Binding DataAdapter.DataProvider.DeferInitialLoad, UpdateSourceTrigger=PropertyChanged}"/>
                    </StackPanel>
                </StackPanel>
            </Expander>

            <Expander
                Header="Query"
                ExpandDirection="Down"
                IsExpanded="True"
                Grid.Row="1"
                Margin="5">
                <Grid Margin="5">
                    <avalonedit:TextEditor
                        ShowLineNumbers="True"
                        Document="{Binding DataProviderDocument}"
                        SyntaxHighlighting="{Binding Highlighting}"/>
                </Grid>
            </Expander>

            <Expander
                Header="Insert Command"
                ExpandDirection="Down"
                Margin="5"
                Grid.Row="2">
                <Grid Margin="5">
                    <avalonedit:TextEditor
                        ShowLineNumbers="True"
                        Document="{Binding InsertDocument}"
                        SyntaxHighlighting="{Binding Highlighting}"/>
                </Grid>
            </Expander>

            <Expander Header="Update Command"
                  ExpandDirection="Down"
                   Margin="5"
                  Grid.Row="3">
                <Grid Margin="5">
                    <avalonedit:TextEditor
                        ShowLineNumbers="True"
                        Document="{Binding UpdateDocument}"
                        SyntaxHighlighting="{Binding Highlighting}"/>
                </Grid>
            </Expander>

            <Expander Header="Delete Command"
                  ExpandDirection="Down"
                   Margin="5"
                  Grid.Row="4">
                <Grid Margin="5">
                    <avalonedit:TextEditor
                        ShowLineNumbers="True"
                        Document="{Binding DeleteDocument}"
                        SyntaxHighlighting="{Binding Highlighting}"/>
                </Grid>
            </Expander>
        </Grid>
    </ScrollViewer>
</UserControl>