<UserControl x:Class="Sprout.Core.Views.SqlServerDataAdapterView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:Sprout.Core.Views"
             xmlns:viewModels="clr-namespace:Sprout.Core.ViewModels"
             xmlns:avalonedit="http://icsharpcode.net/sharpdevelop/avalonedit"
             
             mc:Ignorable="d" 
             Background="Pink"
             d:DataContext="{d:DesignInstance viewModels:SqlServerDataAdapterVM}"
             d:DesignHeight="450" d:DesignWidth="800">
    <ScrollViewer>
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <Expander Header="SQL Server Data Adapter Settings"
                  Grid.Row="0"
                  IsExpanded="True"
                  Margin="5">
                <StackPanel Margin="10">
                    <StackPanel Orientation="Vertical"
                                Margin="0,0,0,5">
                        <Label Content="Connection String:" Width="120"
                               HorizontalAlignment="Left"
                               VerticalAlignment="Center"/>
                        <TextBox MinWidth="200"
                                 HorizontalAlignment="Left"
                                 Text="{Binding DataAdapter.ConnectionString, UpdateSourceTrigger=PropertyChanged}"/>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,5">
                        <Label Content="Command Timeout (seconds):" Width="120" VerticalAlignment="Center"/>
                        <TextBox Width="100" Text="{Binding CommandTimeout, UpdateSourceTrigger=PropertyChanged}"/>
                    </StackPanel>
                    <!--<StackPanel Orientation="Horizontal" Margin="0,0,0,5">
                        <Label Content="Use Integrated Security:" Width="120" VerticalAlignment="Center"/>
                        <CheckBox IsChecked="{Binding UseIntegratedSecurity, UpdateSourceTrigger=PropertyChanged}"/>
                    </StackPanel>-->
                </StackPanel>
            </Expander>

            <Expander
                Header="Query"
                ExpandDirection="Down"
                IsExpanded="True"
                Grid.Row="1"
                Margin="5">
                <Grid Margin="5">
                    <!--<TextBox AcceptsReturn="True"
                         MinHeight="150"
                         AcceptsTab="True"
                         VerticalScrollBarVisibility="Auto"
                         HorizontalScrollBarVisibility="Auto"
                         Text="{Binding DataAdapter.DataProvider.Text, Mode=TwoWay,UpdateSourceTrigger=PropertyChanged}"/>-->
                    
                    <avalonedit:TextEditor
                        ShowLineNumbers="True"
                        Document="{Binding DataProviderDocument}"
                        SyntaxHighlighting="{Binding Highlighting}"
                        />
                </Grid>
            </Expander>

            <Expander
                Header="Insert Command"
                ExpandDirection="Down"
                Margin="5"
                Grid.Row="2">
                <Grid>
                    <TextBox AcceptsReturn="True"
                         MinHeight="150"
                         VerticalScrollBarVisibility="Auto"
                         HorizontalScrollBarVisibility="Auto"
                         Text="{Binding DataAdapter.Insert.Text, Mode=TwoWay,UpdateSourceTrigger=PropertyChanged}"/>
                </Grid>
            </Expander>

            <Expander Header="Update Command"
                  ExpandDirection="Down"
                   Margin="5"
                  Grid.Row="3">
                <Grid>
                    <TextBox AcceptsReturn="True"
                         MinHeight="150"
                         VerticalScrollBarVisibility="Auto"
                         HorizontalScrollBarVisibility="Auto"
                         Text="{Binding DataAdapter.Update.Text, Mode=TwoWay,UpdateSourceTrigger=PropertyChanged}"/>
                </Grid>
            </Expander>

            <Expander Header="Delete Command"
                  ExpandDirection="Down"
                   Margin="5"
                  Grid.Row="4">
                <Grid>
                    <TextBox AcceptsReturn="True"
                         MinHeight="150"
                         VerticalScrollBarVisibility="Auto"
                         HorizontalScrollBarVisibility="Auto"
                         Text="{Binding DataAdapter.Delete.Text, Mode=TwoWay,UpdateSourceTrigger=PropertyChanged}"/>
                </Grid>
            </Expander>
        </Grid>
    </ScrollViewer>
</UserControl>
