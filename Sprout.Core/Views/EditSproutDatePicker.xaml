<UserControl x:Class="Sprout.Core.Views.EditSproutDatePicker"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:Sprout.Core.Views"
             xmlns:config="clr-namespace:Sprout.Core.Models.Configurations"
             xmlns:sys="clr-namespace:System;assembly=System.Runtime"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800"
             d:DataContext="{d:DesignInstance config:SproutDatePickerConfig}">
    <UserControl.Resources>
        <ObjectDataProvider x:Key="DatePickerModes"
                            MethodName="GetValues"
                            ObjectType="{x:Type sys:Enum}">
            <ObjectDataProvider.MethodParameters>
                <x:Type TypeName="config:SproutDatePickerMode"/>
            </ObjectDataProvider.MethodParameters>
        </ObjectDataProvider>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>
    </UserControl.Resources>

    <Grid>
        <TabControl>
            <TabItem Header="General">
                <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="5">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*" MinWidth="150"/>
                        </Grid.ColumnDefinitions>

                        <!--Name-->
                        <TextBlock
                            Grid.Row="0" Grid.Column="0"
                            Margin="5" VerticalAlignment="Center"
                            Text="Name" FontWeight="Bold" FontSize="16"/>
                        <TextBox
                            Grid.Row="0" Grid.Column="1"
                            VerticalAlignment="Center" Margin="5"
                            Text="{Binding Name, UpdateSourceTrigger=PropertyChanged}"/>

                        <!--Label-->
                        <TextBlock
                            Grid.Row="1" Grid.Column="0"
                            Margin="5" VerticalAlignment="Center"
                            Text="Label" FontWeight="Bold" FontSize="16"/>
                        <TextBox
                            Grid.Row="1" Grid.Column="1"
                            VerticalAlignment="Center" Margin="5"
                            Text="{Binding Label, UpdateSourceTrigger=PropertyChanged}"/>

                        <!--Date Mode-->
                        <TextBlock
                            Grid.Row="2" Grid.Column="0"
                            Margin="5" VerticalAlignment="Center"
                            Text="Date Mode" FontWeight="Bold" FontSize="16"/>
                        <ComboBox
                            Grid.Row="2" Grid.Column="1"
                            Margin="5" VerticalAlignment="Center"
                            ItemsSource="{Binding Source={StaticResource DatePickerModes}}"
                            SelectedItem="{Binding DateMode, UpdateSourceTrigger=PropertyChanged}"/>

                        <!--Custom Date-->
                        <TextBlock
                            Grid.Row="3" Grid.Column="0"
                            Margin="5" VerticalAlignment="Center"
                            Text="Custom Date" FontWeight="Bold" FontSize="16"/>
                        <DatePicker
                            Grid.Row="3" Grid.Column="1"
                            Margin="5" VerticalAlignment="Center"
                            SelectedDate="{Binding CustomDate, UpdateSourceTrigger=PropertyChanged}">
                            <DatePicker.Style>
                                <Style TargetType="DatePicker">
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding DateMode}" Value="CurrentDate">
                                            <Setter Property="IsEnabled" Value="False"/>
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding DateMode}" Value="StartOfMonth">
                                            <Setter Property="IsEnabled" Value="False"/>
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding DateMode}" Value="EndOfMonth">
                                            <Setter Property="IsEnabled" Value="False"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </DatePicker.Style>
                        </DatePicker>

                        <!--Day Offset-->
                        <TextBlock
                            Grid.Row="4" Grid.Column="0"
                            Margin="5" VerticalAlignment="Center"
                            Text="Day Offset" FontWeight="Bold" FontSize="16"/>
                        <TextBox
                            Grid.Row="4" Grid.Column="1"
                            Margin="5" VerticalAlignment="Center"
                            Text="{Binding DayOffset, UpdateSourceTrigger=PropertyChanged}"/>

                        <!--Month Offset-->
                        <TextBlock
                            Grid.Row="5" Grid.Column="0"
                            Margin="5" VerticalAlignment="Center"
                            Text="Month Offset" FontWeight="Bold" FontSize="16"/>
                        <TextBox
                            Grid.Row="5" Grid.Column="1"
                            Margin="5" VerticalAlignment="Center"
                            Text="{Binding MonthOffset, UpdateSourceTrigger=PropertyChanged}"/>

                        <!--Output Date Format-->
                        <TextBlock
                            Grid.Row="6" Grid.Column="0"
                            Margin="5" VerticalAlignment="Center"
                            Text="Output Date Format" FontWeight="Bold" FontSize="16"/>
                        <TextBox
                            Grid.Row="6" Grid.Column="1"
                            Margin="5" VerticalAlignment="Center"
                            Text="{Binding OutputDateFormat, UpdateSourceTrigger=PropertyChanged}"
                            ToolTip="C# date format strings:&#x0a;yyyy - Year (2025)&#x0a;MM - Month (01-12)&#x0a;dd - Day (01-31)&#x0a;HH - Hour 24h (00-23)&#x0a;mm - Minute (00-59)&#x0a;ss - Second (00-59)&#x0a;&#x0a;Examples:&#x0a;yyyy-MM-dd → 2025-01-15&#x0a;dd/MM/yyyy → 15/01/2025&#x0a;MM/dd/yyyy → 01/15/2025&#x0a;dd-MMM-yyyy → 15-Jan-2025&#x0a;yyyyMMdd → 20250115"/>
                    </Grid>
                </ScrollViewer>
            </TabItem>

            <TabItem Header="Common">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*" MinWidth="150"/>
                    </Grid.ColumnDefinitions>

                    <!--Height-->
                    <TextBlock
                        Grid.Row="0" Grid.Column="0"
                        Margin="5" VerticalAlignment="Top"
                        Text="Height" FontWeight="Bold" FontSize="16"/>
                    <TextBox
                        Grid.Row="0" Grid.Column="1"
                        VerticalAlignment="Top" Margin="5"
                        Text="{Binding Height, UpdateSourceTrigger=PropertyChanged}"/>

                    <!--Width-->
                    <TextBlock
                        Grid.Row="1" Grid.Column="0"
                        Margin="5" VerticalAlignment="Top"
                        Text="Width" FontWeight="Bold" FontSize="16"/>
                    <TextBox
                        Grid.Row="1" Grid.Column="1"
                        VerticalAlignment="Top" Margin="5"
                        Text="{Binding Width, UpdateSourceTrigger=PropertyChanged}"/>

                    <!--Margin-->
                    <TextBlock
                        Grid.Row="2" Grid.Column="0"
                        Margin="5" VerticalAlignment="Top"
                        Text="Margin" FontWeight="Bold" FontSize="16"/>
                    <TextBox
                        Grid.Row="2" Grid.Column="1"
                        VerticalAlignment="Top" Margin="5"
                        Text="{Binding Margin, UpdateSourceTrigger=PropertyChanged}"/>

                    <!--HorizontalAlignment-->
                    <TextBlock
                        Grid.Row="3" Grid.Column="0"
                        Margin="5" VerticalAlignment="Center"
                        Text="Horizontal Alignment" FontWeight="Bold" FontSize="16"/>
                    <ComboBox
                        Grid.Row="3" Grid.Column="1" Margin="5"
                        SelectedItem="{Binding HorizontalAlignment, UpdateSourceTrigger=PropertyChanged}">
                        <sys:String>(Default)</sys:String>
                        <sys:String>Left</sys:String>
                        <sys:String>Center</sys:String>
                        <sys:String>Right</sys:String>
                        <sys:String>Stretch</sys:String>
                    </ComboBox>

                    <!--VerticalAlignment-->
                    <TextBlock
                        Grid.Row="4" Grid.Column="0"
                        Margin="5" VerticalAlignment="Center"
                        Text="Vertical Alignment" FontWeight="Bold" FontSize="16"/>
                    <ComboBox
                        Grid.Row="4" Grid.Column="1" Margin="5"
                        SelectedItem="{Binding VerticalAlignment, UpdateSourceTrigger=PropertyChanged}">
                        <sys:String>(Default)</sys:String>
                        <sys:String>Top</sys:String>
                        <sys:String>Center</sys:String>
                        <sys:String>Bottom</sys:String>
                        <sys:String>Stretch</sys:String>
                    </ComboBox>

                    <!--ToolTip-->
                    <TextBlock
                        Grid.Row="5" Grid.Column="0"
                        Margin="5" VerticalAlignment="Top"
                        Text="Tooltip" FontWeight="Bold" FontSize="16"/>
                    <TextBox
                        Grid.Row="5" Grid.Column="1"
                        VerticalAlignment="Top" Margin="5"
                        Text="{Binding ToolTip, UpdateSourceTrigger=PropertyChanged}"/>
                </Grid>
            </TabItem>
        </TabControl>
    </Grid>
</UserControl>
