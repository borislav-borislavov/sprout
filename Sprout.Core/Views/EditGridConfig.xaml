<UserControl x:Class="Sprout.Core.Views.EditGridConfig"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:Sprout.Core.Views"
             xmlns:config="clr-namespace:Sprout.Core.Models.Configurations"
             xmlns:viewModels="clr-namespace:Sprout.Core.ViewModels"
             
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800"
             d:DataContext="{d:DesignInstance viewModels:EditPageVM}">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="Auto"/>
            <ColumnDefinition/>
        </Grid.ColumnDefinitions>

        <!--Name-->
        <TextBlock
            Grid.Row="0"
            Grid.Column="0"
            Margin="5"
            VerticalAlignment="Top"
            Text="Name"
            FontWeight="Bold"
            FontSize="16"/>

        <TextBox
            Grid.Row="0"
            Grid.Column="1"
            VerticalAlignment="Top"
            Margin="5"
            Text="{Binding SelectedGridConfig.Name, UpdateSourceTrigger=PropertyChanged}"/>

        <!--ShowGridLines-->
        <TextBlock
            Grid.Row="1"
            Grid.Column="0"
            Margin="5"
            VerticalAlignment="Center"
            Text="Show Grid Lines"
            FontWeight="Bold"
            FontSize="16"/>

        <CheckBox
            Grid.Row="1"
            Grid.Column="1"
            Margin="5"
            VerticalAlignment="Center"
            IsChecked="{Binding SelectedGridConfig.ShowGridLines, UpdateSourceTrigger=PropertyChanged}"/>

        <!--Background-->
        <TextBlock
            Grid.Row="2"
            Grid.Column="0"
            Margin="5"
            VerticalAlignment="Center"
            Text="Background"
            FontWeight="Bold"
            FontSize="16"/>

        <TextBox
            Grid.Row="2"
            Grid.Column="1"
            Margin="5"
            VerticalAlignment="Center"
            Text="{Binding SelectedGridConfig.Background, UpdateSourceTrigger=PropertyChanged}"/>

        <!--Margin-->
        <TextBlock
            Grid.Row="3"
            Grid.Column="0"
            Margin="5"
            VerticalAlignment="Center"
            Text="Margin"
            FontWeight="Bold"
            FontSize="16"/>

        <TextBox
            Grid.Row="3"
            Grid.Column="1"
            Margin="5"
            VerticalAlignment="Center"
            Text="{Binding SelectedGridConfig.Margin, UpdateSourceTrigger=PropertyChanged}"/>

        <!--Rows-->
        <TextBlock
            Grid.Row="4"
            Grid.Column="0"
            Grid.ColumnSpan="2"
            Margin="5"
            VerticalAlignment="Top"
            Text="Rows"
            FontWeight="Bold"
            FontSize="16"/>

        <Grid Grid.Row="5" Grid.Column="0" Grid.ColumnSpan="2" Margin="5">
            <Grid.RowDefinitions>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <Grid.ColumnDefinitions>
                <ColumnDefinition/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <DataGrid
                Name="RowsGrid"
                AutoGenerateColumns="False"
                CanUserAddRows="False"
                HeadersVisibility="All"
                LoadingRow="DataGrid_LoadingRow"
                ItemsSource="{Binding SelectedGridConfig.Rows}"
                Margin="0,0,5,0">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="Row Definition" Width="*">
                        <DataGridTextColumn.Binding>
                            <Binding Path="Value"
                                 UpdateSourceTrigger="PropertyChanged"
                                 ValidatesOnDataErrors="True"
                                 NotifyOnValidationError="True" />
                        </DataGridTextColumn.Binding>

                        <DataGridTextColumn.EditingElementStyle>
                            <Style TargetType="TextBox">
                                <Style.Triggers>
                                    <Trigger Property="Validation.HasError" Value="True">
                                        <Setter Property="ToolTip"
                                            Value="{Binding RelativeSource={RelativeSource Self},
                                            Path=(Validation.Errors)[0].ErrorContent}" />
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </DataGridTextColumn.EditingElementStyle>
                    </DataGridTextColumn>
                </DataGrid.Columns>
            </DataGrid>

            <TextBlock
                Grid.Row="1"
                Margin="5,2,5,0"
                Text="{Binding Items.Count, ElementName=RowsGrid, StringFormat='Total: {0}'}"/>

            <StackPanel Grid.Column="1" Orientation="Vertical" VerticalAlignment="Top">
                <Button Content="Add" Height="30" Width="60" Margin="5" Command="{Binding AddGridRowCommand}" />
                <Button Content="Remove" Height="30" Width="60" Margin="5" Command="{Binding RemoveGridRowCommand}" CommandParameter="{Binding SelectedItem, ElementName=RowsGrid}" />
            </StackPanel>
        </Grid>

        <!--Columns-->
        <TextBlock
            Grid.Row="6"
            Grid.Column="0"
            Grid.ColumnSpan="2"
            Margin="5"
            VerticalAlignment="Top"
            Text="Columns"
            FontWeight="Bold"
            FontSize="16"/>

        <Grid Grid.Row="7" Grid.Column="0" Grid.ColumnSpan="2" Margin="5">
            <Grid.RowDefinitions>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <Grid.ColumnDefinitions>
                <ColumnDefinition/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <DataGrid
                Name="ColumnsGrid"
                AutoGenerateColumns="False"
                CanUserAddRows="False"
                HeadersVisibility="All"
                LoadingRow="DataGrid_LoadingRow"
                ItemsSource="{Binding SelectedGridConfig.Columns}"
                Margin="0,0,5,0">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="Column Definition" Width="*">
                        <DataGridTextColumn.Binding>
                            <Binding Path="Value"
                                 UpdateSourceTrigger="PropertyChanged"
                                 ValidatesOnDataErrors="True"
                                 NotifyOnValidationError="True" />
                        </DataGridTextColumn.Binding>

                        <DataGridTextColumn.EditingElementStyle>
                            <Style TargetType="TextBox">
                                <Style.Triggers>
                                    <Trigger Property="Validation.HasError" Value="True">
                                        <Setter Property="ToolTip"
                                            Value="{Binding RelativeSource={RelativeSource Self},
                                            Path=(Validation.Errors)[0].ErrorContent}" />
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </DataGridTextColumn.EditingElementStyle>
                    </DataGridTextColumn>
                </DataGrid.Columns>
            </DataGrid>

            <TextBlock
                Grid.Row="1"
                Margin="5,2,5,0"
                Text="{Binding Items.Count, ElementName=ColumnsGrid, StringFormat='Total: {0}'}"/>

            <StackPanel Grid.Column="1" Orientation="Vertical" VerticalAlignment="Top">
                <Button Content="Add" Height="30" Width="60" Margin="5" Command="{Binding AddGridColumnCommand}" />
                <Button Content="Remove" Height="30" Width="60" Margin="5" Command="{Binding RemoveGridColumnCommand}" CommandParameter="{Binding SelectedItem, ElementName=ColumnsGrid}" />
            </StackPanel>
        </Grid>
    </Grid>
</UserControl>
