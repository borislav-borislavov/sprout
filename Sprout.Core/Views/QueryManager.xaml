<UserControl x:Class="Sprout.Core.Views.QueryManager"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:Sprout.Core.Views"
             xmlns:viewModels="clr-namespace:Sprout.Core.ViewModels"
             xmlns:views="clr-namespace:Sprout.Core.Views"
             
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800"
             d:DataContext="{d:DesignInstance viewModels:EditPageVM}">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="0.3*"/>
            <ColumnDefinition Width="0.7*"/>
        </Grid.ColumnDefinitions>

        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <ComboBox Name="AdapterTypes"
                  Grid.Column="0"
                  Margin="5"
                  VerticalAlignment="Top"
                  ItemsSource="{Binding AdapterTypes}"
                  SelectedItem="{Binding SelectedAdapterType}"/>

        <Button Content="Change Adapter"
                HorizontalAlignment="Left"
                Margin="5"
                Command="{Binding ChangeAdapterCommand}"
                Grid.Column="1"/>

        <Grid Name="ViewSwitcher"
              Grid.Row="1"
              Grid.Column="0"
              Grid.ColumnSpan="2">
            <Grid.Resources>
                <DataTemplate DataType="{x:Type viewModels:SqlServerDataAdapterVM}">
                    <views:SqlServerDataAdapterView />
                </DataTemplate>
            </Grid.Resources>

            <ContentControl Content="{Binding SelectedAdapterViewModel}" />
        </Grid>
    </Grid>
</UserControl>
