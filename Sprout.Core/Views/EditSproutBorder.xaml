<UserControl x:Class="Sprout.Core.Views.EditSproutBorder"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:Sprout.Core.Views"
             xmlns:config="clr-namespace:Sprout.Core.Models.Configurations"
             xmlns:conv="clr-namespace:Sprout.Core.Converters"
             xmlns:sys="clr-namespace:System;assembly=System.Runtime"

             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800"
             d:DataContext="{d:DesignInstance config:SproutBorderConfig}">
    <UserControl.Resources>
        <conv:NullableDoubleConverter x:Key="NullableDoubleConverter"/>
        <conv:StringToBrushConverter x:Key="StringToBrush"/>
    </UserControl.Resources>

    <Grid>
        <TabControl>
            <TabItem Header="Border">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*" MinWidth="150"/>
                    </Grid.ColumnDefinitions>

                    <!--Name-->
                    <TextBlock
                        Grid.Row="0"
                        Grid.Column="0"
                        Margin="5"
                        VerticalAlignment="Top"
                        Text="Name"
                        FontWeight="Bold"
                        FontSize="16"/>

                    <TextBox
                        Grid.Row="0"
                        Grid.Column="1"
                        VerticalAlignment="Top"
                        Margin="5"
                        Text="{Binding Name, UpdateSourceTrigger=PropertyChanged}"/>

                    <!--Background-->
                    <TextBlock
                        Grid.Row="1"
                        Grid.Column="0"
                        Margin="5"
                        VerticalAlignment="Center"
                        Text="Background"
                        FontWeight="Bold"
                        FontSize="16"/>

                    <Grid Grid.Row="1" Grid.Column="1" Margin="5">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBox Grid.Column="0"
                                 Text="{Binding Background, UpdateSourceTrigger=PropertyChanged}"/>
                        <Border Grid.Column="1"
                                Width="24" Height="24"
                                Margin="6,0,0,0"
                                Background="{Binding Background, Converter={StaticResource StringToBrush}}"
                                BorderBrush="Gray" BorderThickness="1"/>
                    </Grid>

                    <!--BorderBrush-->
                    <TextBlock
                        Grid.Row="2"
                        Grid.Column="0"
                        Margin="5"
                        VerticalAlignment="Center"
                        Text="Border Brush"
                        FontWeight="Bold"
                        FontSize="16"/>

                    <Grid Grid.Row="2" Grid.Column="1" Margin="5">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBox Grid.Column="0"
                                 Text="{Binding BorderBrush, UpdateSourceTrigger=PropertyChanged}"/>
                        <Border Grid.Column="1"
                                Width="24" Height="24"
                                Margin="6,0,0,0"
                                Background="{Binding BorderBrush, Converter={StaticResource StringToBrush}}"
                                BorderBrush="Gray" BorderThickness="1"/>
                    </Grid>

                    <!--BorderThickness-->
                    <TextBlock
                        Grid.Row="3"
                        Grid.Column="0"
                        Margin="5"
                        VerticalAlignment="Top"
                        Text="Border Thickness"
                        FontWeight="Bold"
                        FontSize="16"/>

                    <TextBox
                        Grid.Row="3"
                        Grid.Column="1"
                        VerticalAlignment="Top"
                        Margin="5"
                        Text="{Binding BorderThickness, UpdateSourceTrigger=PropertyChanged}"/>

                    <!--CornerRadius-->
                    <TextBlock
                        Grid.Row="4"
                        Grid.Column="0"
                        Margin="5"
                        VerticalAlignment="Top"
                        Text="Corner Radius"
                        FontWeight="Bold"
                        FontSize="16"/>

                    <TextBox
                        Grid.Row="4"
                        Grid.Column="1"
                        VerticalAlignment="Top"
                        Margin="5"
                        Text="{Binding CornerRadius, UpdateSourceTrigger=PropertyChanged}"/>
                </Grid>
            </TabItem>

            <TabItem Header="Common">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*" MinWidth="150"/>
                    </Grid.ColumnDefinitions>

                    <!--Height-->
                    <TextBlock
                        Grid.Row="0"
                        Grid.Column="0"
                        Margin="5"
                        VerticalAlignment="Top"
                        Text="Height"
                        FontWeight="Bold"
                        FontSize="16"/>

                    <TextBox
                        Grid.Row="0"
                        Grid.Column="1"
                        VerticalAlignment="Top"
                        Margin="5"
                        Text="{Binding Height, UpdateSourceTrigger=PropertyChanged, Converter={StaticResource NullableDoubleConverter}}"/>

                    <!--Width-->
                    <TextBlock
                        Grid.Row="1"
                        Grid.Column="0"
                        Margin="5"
                        VerticalAlignment="Top"
                        Text="Width"
                        FontWeight="Bold"
                        FontSize="16"/>

                    <TextBox
                        Grid.Row="1"
                        Grid.Column="1"
                        VerticalAlignment="Top"
                        Margin="5"
                        Text="{Binding Width, UpdateSourceTrigger=PropertyChanged, Converter={StaticResource NullableDoubleConverter}}"/>

                    <!--Margin-->
                    <TextBlock
                        Grid.Row="2"
                        Grid.Column="0"
                        Margin="5"
                        VerticalAlignment="Top"
                        Text="Margin"
                        FontWeight="Bold"
                        FontSize="16"/>

                    <TextBox
                        Grid.Row="2"
                        Grid.Column="1"
                        VerticalAlignment="Top"
                        Margin="5"
                        Text="{Binding Margin, UpdateSourceTrigger=PropertyChanged}"/>

                    <!--Padding-->
                    <TextBlock
                        Grid.Row="3"
                        Grid.Column="0"
                        Margin="5"
                        VerticalAlignment="Top"
                        Text="Padding"
                        FontWeight="Bold"
                        FontSize="16"/>

                    <TextBox
                        Grid.Row="3"
                        Grid.Column="1"
                        VerticalAlignment="Top"
                        Margin="5"
                        Text="{Binding Padding, UpdateSourceTrigger=PropertyChanged}"/>

                    <!--HorizontalAlignment-->
                    <TextBlock
                        Grid.Row="4"
                        Grid.Column="0"
                        Margin="5"
                        VerticalAlignment="Center"
                        Text="Horizontal Alignment"
                        FontWeight="Bold"
                        FontSize="16"/>

                    <ComboBox
                        Grid.Row="4"
                        Grid.Column="1"
                        Margin="5"
                        SelectedItem="{Binding HorizontalAlignment, UpdateSourceTrigger=PropertyChanged}">
                        <sys:String>(Default)</sys:String>
                        <sys:String>Left</sys:String>
                        <sys:String>Center</sys:String>
                        <sys:String>Right</sys:String>
                        <sys:String>Stretch</sys:String>
                    </ComboBox>

                    <!--VerticalAlignment-->
                    <TextBlock
                        Grid.Row="5"
                        Grid.Column="0"
                        Margin="5"
                        VerticalAlignment="Center"
                        Text="Vertical Alignment"
                        FontWeight="Bold"
                        FontSize="16"/>

                    <ComboBox
                        Grid.Row="5"
                        Grid.Column="1"
                        Margin="5"
                        SelectedItem="{Binding VerticalAlignment, UpdateSourceTrigger=PropertyChanged}">
                        <sys:String>(Default)</sys:String>
                        <sys:String>Top</sys:String>
                        <sys:String>Center</sys:String>
                        <sys:String>Bottom</sys:String>
                        <sys:String>Stretch</sys:String>
                    </ComboBox>

                    <!--ToolTip-->
                    <TextBlock
                        Grid.Row="6"
                        Grid.Column="0"
                        Margin="5"
                        VerticalAlignment="Top"
                        Text="Tooltip"
                        FontWeight="Bold"
                        FontSize="16"/>

                    <TextBox
                        Grid.Row="6"
                        Grid.Column="1"
                        VerticalAlignment="Top"
                        Margin="5"
                        Text="{Binding ToolTip, UpdateSourceTrigger=PropertyChanged}"/>
                </Grid>
            </TabItem>
        </TabControl>
    </Grid>
</UserControl>
