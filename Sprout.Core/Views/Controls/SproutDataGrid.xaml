<UserControl x:Class="Sprout.Core.Views.Controls.SproutDataGrid"
			 xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
			 xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
			 xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
			 xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
			 xmlns:local="clr-namespace:Sprout.Core.Views.Controls"
			 xmlns:conv="clr-namespace:Sprout.Core.Converters"
             xmlns:iconPacks="http://metro.mahapps.com/winfx/xaml/iconpacks"
             
			 mc:Ignorable="d" 
			 d:DesignHeight="450" d:DesignWidth="800"
             >

    <!--d:DataContext="{d:DesignInstance viewModels:EditPageVM}"-->
    <UserControl.Resources>
        <ResourceDictionary>
            <BooleanToVisibilityConverter x:Key="BoolToVis" />
        </ResourceDictionary>
    </UserControl.Resources>

    <Border BorderThickness="0.8" BorderBrush="DarkSlateGray">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="1*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <StackPanel x:Name="gridButtonsPanel" Grid.Row="0" Orientation="Horizontal">

                <Button x:Name="btnFilters"
                        ToolTip="Filter data"
                        Style="{StaticResource FlatRoundButtonStyle}"
                        Visibility="{Binding Config.ShowSave, RelativeSource={RelativeSource AncestorType=local:SproutDataGrid}, Converter={StaticResource BoolToVis}}"
                        HorizontalAlignment="Left"
                        Click="btnFilters_Click"
                        Margin="2">

                    <iconPacks:PackIconMaterialLight  Kind="Magnify"/>
                </Button>

                <Rectangle Width="1" Height="20" Fill="Gray" Margin="5,0"/>

                <Button x:Name="btnInsert"
                        ToolTip="Add new row"
                        Style="{StaticResource FlatRoundButtonStyle}"
                        Visibility="{Binding Config.AllowInsert,
                                     RelativeSource={RelativeSource AncestorType=local:SproutDataGrid},
                                     Converter={StaticResource BoolToVis}}"
                        HorizontalAlignment="Left"
                        Margin="2">
                    <iconPacks:PackIconMaterialLight Kind="Plus" />
                </Button>

                <Button x:Name="btnSave"
                        ToolTip="Save grid changes"
                        Style="{StaticResource FlatRoundButtonStyle}"
                        Visibility="{Binding Config.ShowSave, RelativeSource={RelativeSource AncestorType=local:SproutDataGrid}, Converter={StaticResource BoolToVis}}"
                        HorizontalAlignment="Left"
                        Margin="2">
                    <iconPacks:PackIconMaterialLight Kind="ContentSave" />
                </Button>

                <Button x:Name="btnDelete"
                        ToolTip="Delete row"
                        Style="{StaticResource FlatRoundButtonStyle}"
                        Visibility="{Binding Config.ShowSave,
                                        RelativeSource={RelativeSource AncestorType=local:SproutDataGrid},
                                        Converter={StaticResource BoolToVis}}"
                        HorizontalAlignment="Left"
                        Margin="2">
                    <iconPacks:PackIconMaterialLight Kind="Delete" />
                </Button>

                <Button x:Name="btnRefresh"
                        ToolTip="Refresh data"
                        Style="{StaticResource FlatRoundButtonStyle}"
                        Visibility="{Binding Config.ShowSave, RelativeSource={RelativeSource AncestorType=local:SproutDataGrid}, Converter={StaticResource BoolToVis}}"
                        HorizontalAlignment="Left"
                        Margin="2">
                    <iconPacks:PackIconMaterialLight Kind="Refresh" />
                </Button>
            </StackPanel>

            <Border
                x:Name="filtersBorder"
                Visibility="Collapsed"
                BorderThickness="0, 0, 0 0.8"
                BorderBrush="DarkSlateGray">
            <StackPanel x:Name="filtersButtonPanel"
                        Grid.Row="0"
                        Visibility="Collapsed"
                        Orientation="Horizontal">

                <Button
                    ToolTip="Filter data"
                    Style="{StaticResource FlatRoundButtonStyle}"
                    Visibility="{Binding Config.ShowSave, RelativeSource={RelativeSource AncestorType=local:SproutDataGrid}, Converter={StaticResource BoolToVis}}"
                    HorizontalAlignment="Left"
                    Click="btnFilters_Click"
                    Margin="2">

                    <iconPacks:PackIconMaterialLight Kind="Magnify" />

                </Button>

                <Button
                    x:Name="btnApplyFilters"
                    ToolTip="Apply filters"
                    Style="{StaticResource FlatRoundButtonStyle}"
                    Visibility="{Binding Config.ShowSave, RelativeSource={RelativeSource AncestorType=local:SproutDataGrid}, Converter={StaticResource BoolToVis}}"
                    HorizontalAlignment="Left"
                    Margin="2">

                    <iconPacks:PackIconMaterialLight Kind="Check"/>

                </Button>
            </StackPanel>
            </Border>

            <Grid x:Name="FiltersGrid"
                  Grid.Row="1"
                  Visibility="Collapsed">
                <ScrollViewer
                    HorizontalScrollBarVisibility="Auto"
                    VerticalScrollBarVisibility="Auto">
                    <StackPanel Name="spFilters">

                    </StackPanel>
                </ScrollViewer>
            </Grid>

            <DataGrid
              x:Name="dataGrid"
                
              VirtualizingStackPanel.IsVirtualizing="True"
              VirtualizingStackPanel.VirtualizationMode="Recycling"
              EnableRowVirtualization="True"
              EnableColumnVirtualization="True"
              ScrollViewer.IsDeferredScrollingEnabled="True"
                
              HorizontalGridLinesBrush="#E2E2E2" 
              VerticalGridLinesBrush="#E2E2E2" 
              GridLinesVisibility="All"
                
			  Grid.Row="1"
			  AutoGenerateColumns="False"
			  CanUserAddRows="False"
			  CanUserDeleteRows="False"
			  SelectionMode="Single"
			  SelectionUnit="FullRow"
              BorderThickness="0,0.8,0,0"
              BorderBrush="DarkSlateGray" 
              HeadersVisibility="Column"
              Foreground="DarkSlateGray">
                <DataGrid.Resources>
                    <conv:RowDeletedToOpacityConverter x:Key="DeletedConverter"/>
                    <conv:RowColorConverter x:Key="RowColorConverter"/>
                </DataGrid.Resources>

                <DataGrid.RowStyle>
                    <Style TargetType="DataGridRow">
                        <Setter Property="Opacity">
                            <Setter.Value>
                                <MultiBinding Converter="{StaticResource DeletedConverter}" UpdateSourceTrigger="PropertyChanged">
                                    <Binding Path="." /> <!--this triggers the converter when the view comes back in to view--> 
                                    <Binding Path="[_IsDeleted]" /> <!--This triggers the converter instantly after the value changed-->
                                </MultiBinding>
                            </Setter.Value>
                        </Setter>

                        <Setter Property="Background" Value="White" />

                        <Setter Property="Background">
                            <Setter.Value>
                                <MultiBinding Converter="{StaticResource RowColorConverter}">
                                    <Binding Path="." />
                                    <Binding Path="[_RowBackColor]" />
                                </MultiBinding>
                            </Setter.Value>
                        </Setter>

                        <Style.Triggers>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter Property="Background" Value="{DynamicResource {x:Static SystemColors.HighlightBrushKey}}"/>
                            </Trigger>
                        </Style.Triggers>
                    </Style>
                </DataGrid.RowStyle>
            </DataGrid>

            <Border Grid.Row="2" BorderThickness="0,0.8,0,0" BorderBrush="DarkSlateGray" >
                <StatusBar >
                    <StatusBar.Background>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                            <GradientStop Color="#F0F0F0" Offset="0"/>
                            <GradientStop Color="#D0D0D0" Offset="1"/>
                        </LinearGradientBrush>
                    </StatusBar.Background>

                    <StatusBarItem>
                        <TextBlock x:Name="txtStatusBar"
                               Text="{Binding Items.Count, ElementName=dataGrid, StringFormat={}{0:N0} rows}"
                               />
                    </StatusBarItem>
                </StatusBar>
            </Border>
        </Grid>
    </Border>
</UserControl>
