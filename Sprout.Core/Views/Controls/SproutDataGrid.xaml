<UserControl x:Class="Sprout.Core.Views.Controls.SproutDataGrid"
			 xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
			 xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
			 xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
			 xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
			 xmlns:local="clr-namespace:Sprout.Core.Views.Controls"
             xmlns:iconPacks="http://metro.mahapps.com/winfx/xaml/iconpacks"
             
			 mc:Ignorable="d" 
			 d:DesignHeight="450" d:DesignWidth="800"
             >

    <!--d:DataContext="{d:DesignInstance viewModels:EditPageVM}"-->
    <UserControl.Resources>
        <ResourceDictionary>
            <ControlTemplate x:Key="asd" TargetType="Button">
                <Border x:Name="Border"
                    Background="{TemplateBinding Background}"
                    BorderBrush="{TemplateBinding BorderBrush}"
                    BorderThickness="{TemplateBinding BorderThickness}"
                    CornerRadius="6">
                    <ContentPresenter
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center"/>
                </Border>

                <ControlTemplate.Triggers>
                    <Trigger Property="IsMouseOver" Value="True">
                        <Setter TargetName="Border"
                    Property="Background"
                    Value="#ebfaf0"/>
                    </Trigger>

                    <Trigger Property="IsPressed" Value="True">
                        <Setter TargetName="Border"
                            Property="Background"
                            Value="#c8fad9"/>
                    </Trigger>

                    <Trigger Property="IsEnabled" Value="False">
                        <Setter TargetName="Border"
                    Property="Opacity"
                    Value="0.5"/>
                    </Trigger>
                </ControlTemplate.Triggers>
            </ControlTemplate>

            <BooleanToVisibilityConverter x:Key="BoolToVis" />
        </ResourceDictionary>
    </UserControl.Resources>

    <Border BorderThickness="0.8" BorderBrush="DarkSlateGray">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="1*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <StackPanel x:Name="gridButtonsPanel" Grid.Row="0" Orientation="Horizontal">

                <Button x:Name="btnFilters"
                        ToolTip="Filter data"
                        Template="{StaticResource asd}"
                        Visibility="{Binding Config.ShowSave, RelativeSource={RelativeSource AncestorType=local:SproutDataGrid}, Converter={StaticResource BoolToVis}}"
                        HorizontalAlignment="Left"
                        Click="btnFilters_Click"
                        Margin="2"
                        BorderThickness="0"
                        Background="Transparent">

                    <iconPacks:PackIconMaterialLight  Kind="Magnify" Width="24" Height="24" Foreground="DarkSlateGray" />
                </Button>

                <Rectangle Width="1" Height="25" Fill="Gray" Margin="5,0"/>

                <Button x:Name="btnInsert"
                ToolTip="Add new row"
                Template="{StaticResource asd}"
                Visibility="{Binding Config.AllowInsert,
                             RelativeSource={RelativeSource AncestorType=local:SproutDataGrid},
                             Converter={StaticResource BoolToVis}}"
                HorizontalAlignment="Left"
                Margin="2"
                BorderThickness="0"
                Background="Transparent">
                    <iconPacks:PackIconMaterialLight Kind="Plus" Width="20" Height="20" Foreground="DarkSlateGray" />

                </Button>

                <Button x:Name="btnSave"
                        ToolTip="Save grid changes"
                        Template="{StaticResource asd}"
                        Visibility="{Binding Config.ShowSave, RelativeSource={RelativeSource AncestorType=local:SproutDataGrid}, Converter={StaticResource BoolToVis}}"
                        HorizontalAlignment="Left"
                        Margin="2"
                        BorderThickness="0"
                        Background="Transparent">
                    <iconPacks:PackIconMaterialLight Kind="ContentSave" Width="20" Height="20" Foreground="DarkSlateGray" />
                </Button>

                <Button x:Name="btnDelete"
                    ToolTip="Delete row"
                    Template="{StaticResource asd}"
                    Visibility="{Binding Config.ShowSave,
                                    RelativeSource={RelativeSource AncestorType=local:SproutDataGrid},
                                    Converter={StaticResource BoolToVis}}"
                    HorizontalAlignment="Left"
                    Margin="2"
                    BorderThickness="0"
                    Background="Transparent">
                    <iconPacks:PackIconMaterialLight Kind="Delete" Width="20" Height="20" Foreground="DarkSlateGray" />
                </Button>

                <Button x:Name="btnRefresh"
                        ToolTip="Refresh data"
                        Template="{StaticResource asd}"
                        Visibility="{Binding Config.ShowSave, RelativeSource={RelativeSource AncestorType=local:SproutDataGrid}, Converter={StaticResource BoolToVis}}"
                        HorizontalAlignment="Left"
                        Margin="2"
                        BorderThickness="0"
                        Background="Transparent">

                    <iconPacks:PackIconMaterialLight Kind="Refresh" Width="20" Height="20" Foreground="DarkSlateGray" />
                </Button>
            </StackPanel>

            <Border
                x:Name="filtersBorder"
                Visibility="Collapsed"
                BorderThickness="0, 0, 0 0.8"
                BorderBrush="DarkSlateBlue">
            <StackPanel x:Name="filtersButtonPanel"
                        Grid.Row="0"
                        Visibility="Collapsed"
                        Orientation="Horizontal">

                <Button
                    ToolTip="Filter data"
                    Template="{StaticResource asd}"
                    Visibility="{Binding Config.ShowSave, RelativeSource={RelativeSource AncestorType=local:SproutDataGrid}, Converter={StaticResource BoolToVis}}"
                    HorizontalAlignment="Left"
                    Click="btnFilters_Click"
                    Margin="2"
                    BorderThickness="0"
                    Background="Transparent">

                    <iconPacks:PackIconMaterialLight  Kind="Magnify" Width="24" Height="24" Foreground="DarkSlateGray" />

                </Button>

                <Button
                    x:Name="btnApplyFilters"
                    ToolTip="Apply filters"
                    Template="{StaticResource asd}"
                    Visibility="{Binding Config.ShowSave, RelativeSource={RelativeSource AncestorType=local:SproutDataGrid}, Converter={StaticResource BoolToVis}}"
                    HorizontalAlignment="Left"
                    Margin="2"
                    BorderThickness="0"
                    Background="Transparent">

                    <iconPacks:PackIconMaterialLight  Kind="Check" Width="24" Height="24" Foreground="DarkSlateGray" />

                </Button>
            </StackPanel>
            </Border>

            <Grid x:Name="FiltersGrid"
                  Grid.Row="1"
                  Visibility="Collapsed">
                <ScrollViewer
                    HorizontalScrollBarVisibility="Auto"
                    VerticalScrollBarVisibility="Auto">
                    <StackPanel Name="spFilters">

                    </StackPanel>
                </ScrollViewer>
            </Grid>

            <DataGrid
              x:Name="dataGrid"
			  Grid.Row="1"
			  AutoGenerateColumns="False"
			  CanUserAddRows="False"
			  CanUserDeleteRows="False"
			  SelectionMode="Single"
			  SelectionUnit="FullRow"
              BorderThickness="0,0.8,0,0"
              BorderBrush="DarkSlateGray" 
              HeadersVisibility="Column"
              Foreground="DarkSlateGray">
                <DataGrid.Resources>
                    <Style TargetType="DataGridCell">
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding Row.RowState}" Value="Deleted">
                                <Setter Property="Background" Value="Transparent" />
                                <Setter Property="BorderBrush" Value="Transparent" />
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </DataGrid.Resources>

                <DataGrid.RowStyle>
                    <Style TargetType="DataGridRow">
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding Row.RowState}" Value="Deleted">
                                <Setter Property="Background" Value="#FFFFCCCC" />
                            </DataTrigger>

                            <DataTrigger Binding="{Binding Row.RowState}" Value="Added">
                                <Setter Property="Background" Value="#cdf7e1" />
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </DataGrid.RowStyle>

            </DataGrid>

            <Border Grid.Row="2" BorderThickness="0,0.8,0,0" BorderBrush="DarkSlateGray" >
                <StatusBar >
                    <StatusBar.Background>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                            <GradientStop Color="#F0F0F0" Offset="0"/>
                            <GradientStop Color="#D0D0D0" Offset="1"/>
                        </LinearGradientBrush>
                    </StatusBar.Background>

                    <StatusBarItem>
                        <TextBlock x:Name="txtStatusBar"
                               Foreground="DarkSlateGray"
                               Text="{Binding Items.Count, ElementName=dataGrid, StringFormat={}{0:N0} rows}"
                               />
                    </StatusBarItem>
                </StatusBar>
            </Border>
        </Grid>
    </Border>
</UserControl>
