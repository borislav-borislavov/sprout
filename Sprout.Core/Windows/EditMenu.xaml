<Window x:Class="Sprout.Core.Windows.EditMenu"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:i="http://schemas.microsoft.com/xaml/behaviors"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Sprout.Core.Windows"
        xmlns:conv="clr-namespace:Sprout.Core.Converters"
        xmlns:viewModels="clr-namespace:Sprout.Core.ViewModels"
        
        mc:Ignorable="d"
        d:DataContext="{d:DesignInstance viewModels:EditMenuVM}"
        Title="EditMenu" Height="450" Width="800">

    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis" />
        <conv:InverseBooleanConverter x:Key="InverseBooleanConverter" />
        <conv:StringToBrushConverter x:Key="StringToBrush" />
        <conv:IconStringConverter x:Key="IconStringConverter" />
    </Window.Resources>

    <!--Responsible for Async loading-->
    <i:Interaction.Triggers>
        <i:EventTrigger EventName="Loaded">
            <i:InvokeCommandAction Command="{Binding LoadDataCommand}" />
        </i:EventTrigger>
    </i:Interaction.Triggers>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="0.3*"/>
            <ColumnDefinition Width="0.3*"/>
            <ColumnDefinition Width="0.4*"/>
        </Grid.ColumnDefinitions>

        <ToolBar Grid.Row="0" Grid.ColumnSpan="3" Margin="2">
            <Button Command="{Binding CopyPageAsJsonCommand}" ToolTip="Copy selected page as JSON">
                <StackPanel HorizontalAlignment="Center">
                    <TextBlock FontFamily="Segoe Fluent Icons" Text="&#xE8C8;" HorizontalAlignment="Center"/>
                    <TextBlock Text="Copy Page" HorizontalAlignment="Center"/>
                </StackPanel>
            </Button>
            <Button Command="{Binding CreatePageFromJsonCommand}" ToolTip="Create page from JSON in clipboard">
                <StackPanel HorizontalAlignment="Center">
                    <TextBlock FontFamily="Segoe Fluent Icons" Text="&#xE77F;" HorizontalAlignment="Center"/>
                    <TextBlock Text="Paste Page" HorizontalAlignment="Center"/>
                </StackPanel>
            </Button>
        </ToolBar>

        <Grid Name="MenuItems"
              Grid.Row="1"
              Grid.Column="0">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <TextBlock
                Grid.Row="0"
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                Text="Menu Items"
                Foreground="Black"
                FontWeight="Bold"
                FontSize="16"
                Margin="5"/>

            <ListBox
                Name="MenuItemsList"
                Grid.Row="1"
                Margin="5"
                IsEnabled="{Binding LoadDataCommand.IsRunning, Converter={StaticResource InverseBooleanConverter}}"
                ItemsSource="{Binding PageConfigs}"
                SelectedItem="{Binding SelectedPageConfig}">
                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <TextBlock Text="{Binding Title}"/>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>

            <StackPanel
                Grid.Row="1"
                VerticalAlignment="Center" 
                HorizontalAlignment="Center"
                Visibility="{Binding LoadDataCommand.IsRunning, Converter={StaticResource BoolToVis}}">

                <!--<ProgressBar 
                     IsIndeterminate="True" 
                     Width="100" 
                     Height="10"/>-->

                <TextBlock Text="Loading..."
                   HorizontalAlignment="Center"
                   Margin="0,10,0,0" />
            </StackPanel>

            <StackPanel Name="Buttons"
                        Grid.Row="2"
                        Orientation="Horizontal">
                <Button
                    HorizontalAlignment="Left"
                    Margin="2"
                    BorderThickness="0"
                    Background="Transparent"
                    Command="{Binding CreateNewCommand}">
                        <TextBlock
                            FontFamily="Segoe Fluent Icons"
                            FontSize="25"
                            Text="&#xE948;"
                            Margin="3"/>
                </Button>

                <Button
                    HorizontalAlignment="Left"
                    Margin="2"
                    BorderThickness="0"
                    Background="Transparent"
                    Command="{Binding DeleteSelectedCommand}" >
                    <TextBlock
                            FontFamily="Segoe Fluent Icons"
                            FontSize="25"
                            Text="&#xE949;"
                            Margin="3"/>
                </Button>

                <Button
                    HorizontalAlignment="Left"
                    Margin="2"
                    BorderThickness="0"
                    Background="Transparent"
                    ToolTip="Duplicate selected page"
                    Command="{Binding DuplicateSelectedCommand}">
                    <TextBlock
                            FontFamily="Segoe Fluent Icons"
                            FontSize="25"
                            Text="&#xE8C8;"
                            Margin="3"/>
                </Button>

                <Button
                    HorizontalAlignment="Left"
                    Margin="2"
                    BorderThickness="0"
                    Background="Transparent"
                    Command="{Binding MoveUpCommand}">
                    <TextBlock
                            FontFamily="Segoe Fluent Icons"
                            FontSize="25"
                            Text="&#xE74A;"
                            Margin="3"/>
                </Button>

                <Button
                    HorizontalAlignment="Left"
                    Margin="2"
                    BorderThickness="0"
                    Background="Transparent"
                    Command="{Binding MoveDownCommand}">
                    <TextBlock
                            FontFamily="Segoe Fluent Icons"
                            FontSize="25"
                            Text="&#xE74B;"
                            Margin="3"/>
                </Button>
            </StackPanel>

        </Grid>

        <Grid Name="Categories"
              Grid.Row="1"
              Grid.Column="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <TextBlock
                Grid.Row="0"
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                Text="Categories"
                Foreground="Black"
                FontWeight="Bold"
                FontSize="16"
                Margin="5"/>

            <ListBox
                Name="CategoriesList"
                Grid.Row="1"
                Margin="5"
                IsEnabled="{Binding LoadDataCommand.IsRunning, Converter={StaticResource InverseBooleanConverter}}"
                ItemsSource="{Binding Categories}"
                SelectedItem="{Binding SelectedCategory}">
                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <StackPanel>
                            <TextBlock Text="{Binding Title}" FontWeight="Bold"/>
                            <ItemsControl ItemsSource="{Binding Pages}" Margin="12,0,0,0">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding Title}" Foreground="Gray"/>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>

            <StackPanel Name="CategoryButtons"
                        Grid.Row="2"
                        Orientation="Horizontal">
                <Button
                    HorizontalAlignment="Left"
                    Margin="2"
                    BorderThickness="0"
                    Background="Transparent"
                    ToolTip="New Category"
                    Command="{Binding CreateNewCategoryCommand}">
                        <TextBlock
                            FontFamily="Segoe Fluent Icons"
                            FontSize="25"
                            Text="&#xE948;"
                            Margin="3"/>
                </Button>

                <Button
                    HorizontalAlignment="Left"
                    Margin="2"
                    BorderThickness="0"
                    Background="Transparent"
                    ToolTip="Delete Category"
                    Command="{Binding DeleteSelectedCategoryCommand}" >
                    <TextBlock
                            FontFamily="Segoe Fluent Icons"
                            FontSize="25"
                            Text="&#xE949;"
                            Margin="3"/>
                </Button>

                <Button
                    HorizontalAlignment="Left"
                    Margin="2"
                    BorderThickness="0"
                    Background="Transparent"
                    ToolTip="Move Category Up"
                    Command="{Binding MoveCategoryUpCommand}">
                    <TextBlock
                            FontFamily="Segoe Fluent Icons"
                            FontSize="25"
                            Text="&#xE74A;"
                            Margin="3"/>
                </Button>

                <Button
                    HorizontalAlignment="Left"
                    Margin="2"
                    BorderThickness="0"
                    Background="Transparent"
                    ToolTip="Move Category Down"
                    Command="{Binding MoveCategoryDownCommand}">
                    <TextBlock
                            FontFamily="Segoe Fluent Icons"
                            FontSize="25"
                            Text="&#xE74B;"
                            Margin="3"/>
                </Button>
            </StackPanel>

            <StackPanel Grid.Row="3" Margin="5">
                <TextBlock Text="Category Title"/>
                <TextBox Text="{Binding SelectedCategory.Title, UpdateSourceTrigger=PropertyChanged}" Margin="0,2"/>

                <TextBlock Text="Background Color" Margin="0,5,0,0"/>
                <Grid Margin="0,2">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <TextBox Grid.Column="0"
                             Text="{Binding SelectedCategory.BackgroundColor, UpdateSourceTrigger=PropertyChanged}"/>

                    <Border Grid.Column="1"
                            Width="24"
                            Margin="5,0,0,0"
                            CornerRadius="3"
                            BorderBrush="Gray"
                            BorderThickness="1"
                            Background="{Binding SelectedCategory.BackgroundColor, Converter={StaticResource StringToBrush}}"/>
                </Grid>

                <Button Content="Assign Selected Page →"
                        Margin="0,5,0,0"
                        Padding="5"
                        Command="{Binding AssignSelectedPageToCategoryCommand}"/>

                <Button Content="Remove Page From Category"
                        Margin="0,5,0,0"
                        Padding="5"
                        Command="{Binding RemoveSelectedPageFromCategoryCommand}"/>
            </StackPanel>
        </Grid>

        <Grid Name="DisplaySelectedMenuItem"
              Grid.Row="1"
              Grid.Column="2">
            <Grid.RowDefinitions>
                <RowDefinition/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <StackPanel>
                <TextBlock Text="Title"/>
                <TextBox Text="{Binding SelectedPageConfig.Title, UpdateSourceTrigger=PropertyChanged}" Margin="5"/>

                <CheckBox Content="AddToMenu" IsChecked="{Binding SelectedPageConfig.AddToMenu}" Margin="5" />

                <TextBlock Text="Icon" Margin="5,5,5,0"/>
                <Grid Margin="5,2">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBox Grid.Column="0"
                             Text="{Binding SelectedPageConfig.Icon, UpdateSourceTrigger=PropertyChanged, Converter={StaticResource IconStringConverter}}"/>
                    <TextBlock Grid.Column="1"
                               Margin="5,0,0,0"
                               FontSize="20"
                               VerticalAlignment="Center"
                               Text="{Binding SelectedPageConfig.Icon}"
                               FontFamily="{Binding SelectedPageConfig.IconFont}"/>
                </Grid>

                <TextBlock Text="Icon Font" Margin="5,5,5,0"/>
                <TextBox Text="{Binding SelectedPageConfig.IconFont, UpdateSourceTrigger=PropertyChanged}" Margin="5,2"/>
            </StackPanel>

            <Button Content="Save"
                    Grid.Row="1"
                    Grid.Column="1"
                    HorizontalAlignment="Left"
                    Margin="5"
                    Padding="5"
                    Command="{Binding SaveCommand}"
                    />
        </Grid>
    </Grid>
</Window>
