<Window x:Class="Sprout.Core.Windows.ColumnSettings"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Sprout.Core.Windows"
        xmlns:viewModels="clr-namespace:Sprout.Core.ViewModels"
        mc:Ignorable="d"
        d:DataContext="{d:DesignInstance viewModels:ColumnSettingsVM}"
        Title="Column Settings" Height="450" Width="380"
        WindowStartupLocation="CenterOwner">

    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0"
                   Text="Show, hide and reorder columns"
                   FontWeight="Bold"
                   Foreground="DarkSlateGray"
                   Margin="0,0,0,4"/>

        <CheckBox Grid.Row="1"
                  Content="Select all"
                  IsChecked="{Binding AllColumnsVisible}"
                  Margin="2,0,0,6"/>

        <Grid Grid.Row="2" Margin="0,0,0,6">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <TextBox Grid.Column="0"
                     Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}">
                <TextBox.Style>
                    <Style TargetType="TextBox">
                        <Style.Resources>
                            <VisualBrush x:Key="HintBrush" AlignmentX="Left" AlignmentY="Center" Stretch="None">
                                <VisualBrush.Visual>
                                    <TextBlock Text="🔍  Search columns…" Foreground="Gray" Margin="4,0,0,0"/>
                                </VisualBrush.Visual>
                            </VisualBrush>
                        </Style.Resources>
                        <Style.Triggers>
                            <Trigger Property="Text" Value="">
                                <Setter Property="Background" Value="{StaticResource HintBrush}"/>
                            </Trigger>
                        </Style.Triggers>
                    </Style>
                </TextBox.Style>
            </TextBox>
            <Button Grid.Column="1"
                    Content="✕"
                    Width="24"
                    Margin="4,0,0,0"
                    Padding="0"
                    FontSize="10"
                    ToolTip="Clear search"
                    Command="{Binding ClearSearchCommand}"
                    Focusable="False">
                <Button.Style>
                    <Style TargetType="Button">
                        <Setter Property="Visibility" Value="Visible"/>
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding SearchText}" Value="">
                                <Setter Property="Visibility" Value="Collapsed"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Button.Style>
            </Button>
        </Grid>

        <Grid Grid.Row="3">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <ListBox x:Name="ColumnsList"
                     Grid.Column="0"
                     ItemsSource="{Binding FilteredColumns}"
                     SelectedItem="{Binding SelectedColumn}">
                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <CheckBox Content="{Binding Key}"
                                  IsChecked="{Binding IsVisible}"/>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>

            <StackPanel Grid.Column="1"
                        VerticalAlignment="Center"
                        Margin="8,0,0,0">
                <Button Content="▲"
                        ToolTip="Move up"
                        Width="32"
                        Margin="0,0,0,4"
                        Command="{Binding MoveUpCommand}"/>
                <Button Content="▼"
                        ToolTip="Move down"
                        Width="32"
                        Command="{Binding MoveDownCommand}"/>
            </StackPanel>
        </Grid>

        <StackPanel Grid.Row="4"
                    Orientation="Horizontal"
                    Margin="0,10,0,0">
            <TextBlock Text="Lock first"
                       VerticalAlignment="Center"/>
            <TextBox Text="{Binding FrozenColumnCount, UpdateSourceTrigger=PropertyChanged}"
                     Width="50"
                     Margin="5,0"
                     VerticalAlignment="Center"/>
            <TextBlock Text="column(s)"
                       VerticalAlignment="Center"/>
        </StackPanel>

        <Grid Grid.Row="5" Margin="0,12,0,0">
            <Button Content="Reset to Default"
                    Padding="20,5"
                    HorizontalAlignment="Left"
                    Command="{Binding ResetToDefaultCommand}"/>
            <StackPanel Orientation="Horizontal"
                        HorizontalAlignment="Right">
                <Button Content="Save"
                        Padding="20,5"
                        Margin="0,0,8,0"
                        Click="SaveButton_Click"/>
                <Button Content="Cancel"
                        Padding="20,5"
                        IsCancel="True"/>
            </StackPanel>
        </Grid>
    </Grid>
</Window>
