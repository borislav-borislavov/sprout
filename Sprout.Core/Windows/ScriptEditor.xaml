<Window x:Class="Sprout.Core.Windows.ScriptEditor"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Sprout.Core.Windows"
        xmlns:avalonEdit="http://icsharpcode.net/sharpdevelop/avalonedit"
        xmlns:viewModels="clr-namespace:Sprout.Core.ViewModels"
        mc:Ignorable="d"
        d:DataContext="{d:DesignInstance viewModels:ScriptEditorVM}"
        Title="Script Editor"
        Height="700" Width="1000"
        WindowStartupLocation="CenterScreen"
        Background="#1F1F1F">

    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>

        <Style x:Key="{x:Static ToolBar.ButtonStyleKey}" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Padding" Value="7,5"/>
            <Setter Property="ToolTipService.ShowOnDisabled" Value="True"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Border"
                                Background="{TemplateBinding Background}"
                                BorderThickness="0"
                                Padding="{TemplateBinding Padding}"
                                CornerRadius="3">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Border" Property="Background" Value="#2D2D2D"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Border" Property="Background" Value="#094771"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="Border" Property="Opacity" Value="0.35"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="{x:Static ToolBar.SeparatorStyleKey}" TargetType="Separator">
            <Setter Property="Background" Value="#3C3C3C"/>
            <Setter Property="Width" Value="1"/>
            <Setter Property="Margin" Value="4,4"/>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- ── Toolbar ── -->
        <ToolBarTray Grid.Row="0" Background="#2C2C2C" IsLocked="True">
            <ToolBar Background="#2C2C2C"
                     Loaded="ToolBar_Loaded"
                     Band="0" BandIndex="0">
                <Button Command="{Binding SaveCommand}"
                        ToolTip="Save (Ctrl+S)" >
                    <TextBlock Text="&#xE74E;" FontFamily="Segoe MDL2 Assets" FontSize="15" Foreground="White"/>
                </Button>
                <Separator/>
                <Button Command="{Binding CopyCommand}"
                        ToolTip="Copy all">
                    <TextBlock Text="&#xE8C8;" FontFamily="Segoe MDL2 Assets" FontSize="15" Foreground="White"/>
                </Button>
                <Separator/>
                <Button Command="{Binding CompileCommand}"
                        ToolTip="Compile">
                    <TextBlock Text="&#xE9F5;" FontFamily="Segoe MDL2 Assets" FontSize="15" Foreground="White"/>
                </Button>
                <Separator/>
                <Button Command="{Binding ManageUsingsCommand}"
                        ToolTip="Manage additional usings">
                    <TextBlock Text="&#xE71D;" FontFamily="Segoe MDL2 Assets" FontSize="15" Foreground="White"/>
                </Button>
            </ToolBar>
        </ToolBarTray>

        <!-- ── Editor ── -->
        <avalonEdit:TextEditor
            x:Name="Editor"
            Grid.Row="1"
            Document="{Binding Document}"
            SyntaxHighlighting="{Binding Highlighting}"
            FontFamily="Cascadia Code, Consolas, Courier New"
            FontSize="14"
            ShowLineNumbers="True"
            Background="#1F1F1F"
            Foreground="#D4D4D4"
            LineNumbersForeground="#4A4A4A"
            WordWrap="False"
            HorizontalScrollBarVisibility="Auto"
            VerticalScrollBarVisibility="Auto"
            BorderThickness="0"
            Padding="4,0,0,0"/>

        <!-- ── Output ── -->
        <Expander x:Name="OutputExpander"
                  Grid.Row="2"
                  Background="#252526"
                  Foreground="#D4D4D4"
                  BorderBrush="#3C3C3C"
                  BorderThickness="0,1,0,0"
                  IsExpanded="False">
            <Expander.Header>
                <TextBlock VerticalAlignment="Center"
                           FontFamily="Cascadia Code, Consolas, Courier New"
                           FontSize="12">
                    <TextBlock.Style>
                        <Style TargetType="TextBlock">
                            <Setter Property="Foreground" Value="#57A64A"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsCompileSuccess}" Value="False">
                                    <Setter Property="Foreground" Value="#F44747"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </TextBlock.Style>
                    <Run Text="Output  —  "/>
                    <Run Text="{Binding CompileStatusText, Mode=OneWay}"/>
                </TextBlock>
            </Expander.Header>
            <TextBox Text="{Binding OutputText, Mode=OneWay}"
                     IsReadOnly="True"
                     Background="#1C1C1C"
                     Foreground="#D4D4D4"
                     FontFamily="Cascadia Code, Consolas, Courier New"
                     FontSize="12"
                     BorderThickness="0"
                     Padding="10,6"
                     TextWrapping="NoWrap"
                     Height="200"
                     VerticalScrollBarVisibility="Auto"
                     HorizontalScrollBarVisibility="Auto"
                     AcceptsReturn="True"
                     CaretBrush="Transparent"/>
        </Expander>
    </Grid>
</Window>
