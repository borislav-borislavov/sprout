<Window x:Class="Sprout.Core.Windows.ScriptEditor"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Sprout.Core.Windows"
        xmlns:avalonEdit="http://icsharpcode.net/sharpdevelop/avalonedit"
        xmlns:viewModels="clr-namespace:Sprout.Core.ViewModels"
        mc:Ignorable="d"
        d:DataContext="{d:DesignInstance viewModels:ScriptEditorVM}"
        Title="Script Editor"
        Height="700" Width="1000"
        WindowStartupLocation="CenterScreen"
        Background="#1F1F1F">

    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>

        <Style x:Key="ToolbarButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Foreground" Value="#CCCCCC"/>
            <Setter Property="Padding" Value="7,5"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
            <Setter Property="FontFamily" Value="Segoe MDL2 Assets"/>
            <Setter Property="FontSize" Value="15"/>
            <Setter Property="ToolTipService.ShowOnDisabled" Value="True"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Border"
                                Background="{TemplateBinding Background}"
                                BorderThickness="0"
                                Padding="{TemplateBinding Padding}"
                                CornerRadius="3">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Border" Property="Background" Value="#2D2D2D"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Border" Property="Background" Value="#094771"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="Border" Property="Opacity" Value="0.35"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- ── Toolbar ── -->
        <Border Grid.Row="0"
                Background="#2C2C2C"
                BorderBrush="#3C3C3C"
                BorderThickness="0,0,0,1"
                Padding="4,3">
            <StackPanel Orientation="Horizontal">

                <Button Style="{StaticResource ToolbarButtonStyle}"
                        Command="{Binding SaveCommand}"
                        ToolTip="Save (Ctrl+S)"
                        Content="&#xE74E;"/>

                <Separator Width="1" Background="#3C3C3C" Margin="4,4"/>

                <Button Style="{StaticResource ToolbarButtonStyle}"
                        Command="{Binding CopyCommand}"
                        ToolTip="Copy all"
                        Content="&#xE8C8;"/>

                <Separator Width="1" Background="#3C3C3C" Margin="4,4"/>

                <Button Style="{StaticResource ToolbarButtonStyle}"
                        Command="{Binding CompileCommand}"
                        ToolTip="Compile"
                        Content="&#xE9F5;"/>

            </StackPanel>
        </Border>

        <!-- ── Editor + Output ── -->
        <Grid Grid.Row="1" x:Name="EditorOutputGrid">
            <Grid.RowDefinitions>
                <RowDefinition Height="*" MinHeight="80"/>
                    <RowDefinition Height="0"/>
                    <RowDefinition Height="0" MinHeight="60"/>
            </Grid.RowDefinitions>

            <!-- Editor -->
            <avalonEdit:TextEditor
                x:Name="Editor"
                Grid.Row="0"
                Document="{Binding Document}"
                SyntaxHighlighting="{Binding Highlighting}"
                FontFamily="Cascadia Code, Consolas, Courier New"
                FontSize="14"
                ShowLineNumbers="True"
                Background="#1F1F1F"
                Foreground="#D4D4D4"
                LineNumbersForeground="#4A4A4A"
                WordWrap="False"
                HorizontalScrollBarVisibility="Auto"
                VerticalScrollBarVisibility="Auto"
                BorderThickness="0"
                Padding="4,0,0,0"/>

            <!-- ── Splitter ── -->
            <GridSplitter Grid.Row="1"
                          Height="4"
                          HorizontalAlignment="Stretch"
                          Background="#3C3C3C"
                          ResizeDirection="Rows"
                          ResizeBehavior="PreviousAndNext"
                          Cursor="SizeNS"/>

            <!-- ── Output panel ── -->
            <Border Grid.Row="2"
                    Background="#1C1C1C"
                    BorderBrush="#3C3C3C"
                    BorderThickness="0,0,0,0">
                <DockPanel>

                    <!-- Header bar -->
                    <Border DockPanel.Dock="Top"
                            Background="#252526"
                            BorderBrush="#3C3C3C"
                            BorderThickness="0,0,0,1"
                            Padding="10,4,4,4">
                        <DockPanel>
                            <Button DockPanel.Dock="Right"
                                    Style="{StaticResource ToolbarButtonStyle}"
                                    Command="{Binding CloseOutputCommand}"
                                    ToolTip="Close output"
                                    Content="&#xE711;"
                                    Padding="5,3"/>

                            <TextBlock VerticalAlignment="Center"
                                       FontFamily="Cascadia Code, Consolas, Courier New"
                                       FontSize="12">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Foreground" Value="#57A64A"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsCompileSuccess}" Value="False">
                                                <Setter Property="Foreground" Value="#F44747"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                                <Run Text="Output  —  "/>
                                <Run Text="{Binding CompileStatusText, Mode=OneWay}"/>
                            </TextBlock>
                        </DockPanel>
                    </Border>

                    <!-- Selectable, scrollable output text -->
                    <TextBox DockPanel.Dock="Bottom"
                             Text="{Binding OutputText, Mode=OneWay}"
                             IsReadOnly="True"
                             Background="#1C1C1C"
                             Foreground="#D4D4D4"
                             FontFamily="Cascadia Code, Consolas, Courier New"
                             FontSize="12"
                             BorderThickness="0"
                             Padding="10,6"
                             TextWrapping="NoWrap"
                             VerticalScrollBarVisibility="Auto"
                             HorizontalScrollBarVisibility="Auto"
                             AcceptsReturn="True"
                             CaretBrush="Transparent"/>
                </DockPanel>
            </Border>
        </Grid>
    </Grid>
</Window>
