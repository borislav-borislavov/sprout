<Window x:Class="Sprout.Core.Windows.EditLoginConfig"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Sprout.Core.Windows"
        xmlns:viewModels="clr-namespace:Sprout.Core.ViewModels"
        mc:Ignorable="d"
        d:DataContext="{d:DesignInstance viewModels:EditLoginConfigVM}"
        Title="Edit Login Configuration" Height="450" Width="600">
    <Grid Margin="15">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Enable / Disable Login -->
        <CheckBox Grid.Row="0"
                  Content="Enable Login"
                  IsChecked="{Binding IsLoginEnabled, UpdateSourceTrigger=PropertyChanged}"
                  Margin="0,0,0,10"/>

        <!-- Data Adapter Type -->
        <StackPanel Grid.Row="1"
                    Margin="0,0,0,10"
                    IsEnabled="{Binding IsLoginEnabled}">
            <Label Content="Data Adapter Type:" Padding="0" Margin="0,0,0,4"/>
            <ComboBox ItemsSource="{Binding AdapterTypes}"
                      SelectedItem="{Binding SelectedAdapterType, UpdateSourceTrigger=PropertyChanged}"
                      Width="200"
                      HorizontalAlignment="Left"/>
        </StackPanel>

        <!-- Update Command -->
        <GroupBox Grid.Row="2"
                  Header="Update Command"
                  IsEnabled="{Binding IsLoginEnabled}"
                  Margin="0,0,0,10">
            <TextBox Text="{Binding UpdateCommandText, UpdateSourceTrigger=PropertyChanged}"
                     AcceptsReturn="True"
                     AcceptsTab="True"
                     VerticalScrollBarVisibility="Auto"
                     HorizontalScrollBarVisibility="Auto"
                     FontFamily="Consolas"
                     FontSize="13"/>
        </GroupBox>

        <!-- Save Button -->
        <Button Grid.Row="3"
                Content="Save"
                Command="{Binding SaveCommand}"
                HorizontalAlignment="Right"
                Padding="20,5"
                MinWidth="100"/>
    </Grid>
</Window>
